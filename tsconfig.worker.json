{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "noEmit": false,
    "lib": ["ES2020"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "worker.ts",
    "src/lib/queue.ts",
    "src/lib/prisma.ts",
    "src/workers/**/*"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "src/app",
    "src/components",
    "src/hooks",
    "src/i18n"
  ]
}
